# JavaScript Coding Patterns

This guide provides practical coding patterns and examples for JavaScript/TypeScript development in the Michelangelo project. It includes real-world examples from the codebase and best practices for common development scenarios.

## React Component Patterns

### Basic Component Structure
Follow the established pattern from [packages/core/components/](mdc:javascript/packages/core/components):

```tsx
import { memo } from 'react';
import { useStyletron } from 'baseui';

import type { Props } from './types';

export const MyComponent = memo<Props>(function MyComponent(props) {
  const [css, theme] = useStyletron();
  const { children, title, loading = false } = props;

  if (loading) {
    return <div>Loading...</div>;
  }

  return (
    <div className={css({ padding: theme.sizing.scale400 })}>
      <h1>{title}</h1>
      {children}
    </div>
  );
});
```

### Override Pattern for Customization
Use BaseUI's override pattern for component customization:

```tsx
import { getOverrides } from 'baseui';
import { StyledContainer, StyledHeader } from './styled-components';

export function CustomizableComponent(props: Props) {
  const { overrides = {}, children, title } = props;

  const [Container, containerProps] = getOverrides(
    overrides.Container,
    StyledContainer
  );
  
  const [Header, headerProps] = getOverrides(
    overrides.Header,
    StyledHeader
  );

  return (
    <Container {...containerProps}>
      <Header {...headerProps}>{title}</Header>
      {children}
    </Container>
  );
}
```

