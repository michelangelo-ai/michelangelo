### Icon Component Pattern
Pattern from [packages/core/components/icon/icon.tsx](mdc:javascript/packages/core/components/icon/icon.tsx):

```tsx
import { memo } from 'react';
import { useStyletron } from 'baseui';
import { useIconProvider } from '#core/providers/icon-provider/use-icon-provider';

export const Icon = memo<Props>(function Icon(props) {
  const [, theme] = useStyletron();
  const { color, name, icon, kind = IconKind.PRIMARY } = props;
  const { icons } = useIconProvider();

  const IconComponent = icon ?? (name ? icons[name] : null);

  if (!IconComponent) return null;

  return (
    <IconComponent
      {...props}
      color={color ?? theme.colors[`content${capitalizeFirstLetter(kind)}`]}
      style={{ minWidth: 'fit-content' }}
    />
  );
});
```

## Custom Hook Patterns

### Data Fetching Hook
Pattern from [packages/core/hooks/use-studio-query.ts](mdc:javascript/packages/core/hooks/use-studio-query.ts):

```tsx
import { useQuery } from '@tanstack/react-query';
import { useServiceProvider } from '#core/providers/service-provider/use-service-provider';

export function useStudioQuery<TData = unknown>(
  options: QueryOptions<TData>
): UseQueryResult<TData> {
  const { request } = useServiceProvider();
  const { projectId } = useStudioParams('base');

  return useQuery({
    queryKey: [options.queryName, options.serviceOptions],
    queryFn: async () => {
      return await request(options.queryName, {
        ...options.serviceOptions,
        namespace: projectId,
      });
    },
    ...options.queryOptions,
  });
}
```

### URL Parameter Hook
Pattern from [packages/core/hooks/routing/use-studio-params.ts](mdc:javascript/packages/core/hooks/routing/use-studio-params.ts):

```tsx
import { useParams } from 'react-router-dom-v5-compat';

export function useStudioParams<T extends ParamType>(
  type: T
): StudioParams[T] {
  const params = useParams();
  
  return {
    projectId: params.projectId || '',
    ...params
  } as StudioParams[T];
}
```

### URL Query String Hook
Pattern from [packages/core/hooks/routing/use-url-query-string.ts](mdc:javascript/packages/core/hooks/routing/use-url-query-string.ts):

```tsx
import { useLocation } from 'react-router-dom-v5-compat';

export function useURLQueryString<T extends Record<string, string>>(): T {
  const location = useLocation();
  
  return useMemo(() => {
    const searchParams = new URLSearchParams(location.search);
    const params: Record<string, string> = {};
    
    searchParams.forEach((value, key) => {
      params[key] = value;
    });
    
    return params as T;
  }, [location.search]);
}
```

## Provider Patterns

### Service Provider
Pattern from [packages/core/providers/service-provider/](mdc:javascript/packages/core/providers/service-provider):

```tsx
import { createContext, useContext } from 'react';
import type { ServiceContextType } from './types';

const ServiceContext = createContext<ServiceContextType | null>(null);

export function ServiceProvider({ children, ...serviceContext }: Props) {
  return (
    <ServiceContext.Provider value={serviceContext}>
      {children}
    </ServiceContext.Provider>
  );
}

export function useServiceProvider(): ServiceContextType {
  const context = useContext(ServiceContext);
  if (!context) {
    throw new Error('useServiceProvider must be used within ServiceProvider');
  }
  return context;
}
```

### Icon Provider
Pattern from [packages/core/providers/icon-provider/](mdc:javascript/packages/core/providers/icon-provider):

```tsx
import { createContext, useContext } from 'react';
import type { IconProviderContext } from './types';

const IconContext = createContext<IconProviderContext | null>(null);

export function IconProvider({ children, icons }: Props) {
  const value = useMemo(() => ({ icons }), [icons]);
  
  return (
    <IconContext.Provider value={value}>
      {children}
    </IconContext.Provider>
  );
}

export function useIconProvider(): IconProviderContext {
  const context = useContext(IconContext);
  if (!context) {
    throw new Error('useIconProvider must be used within IconProvider');
  }
  return context;
}
```

## State Management Patterns

### React Query Integration
Pattern for server state management:

```tsx
import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query';

export function useProjectData(projectId: string) {
  return useQuery({
    queryKey: ['project', projectId],
    queryFn: () => fetchProject(projectId),
    enabled: !!projectId,
  });
}

export function useUpdateProject() {
  const queryClient = useQueryClient();
  
  return useMutation({
    mutationFn: updateProject,
    onSuccess: (data) => {
      queryClient.setQueryData(['project', data.id], data);
      queryClient.invalidateQueries({ queryKey: ['projects'] });
    },
  });
}
```

### Local State with Reducer
Pattern for complex local state:

```tsx
import { useReducer } from 'react';

interface State {
  loading: boolean;
  error: string | null;
  data: any[];
}

type Action = 
  | { type: 'LOADING' }
  | { type: 'SUCCESS'; payload: any[] }
  | { type: 'ERROR'; payload: string };

function reducer(state: State, action: Action): State {
  switch (action.type) {
    case 'LOADING':
      return { ...state, loading: true, error: null };
    case 'SUCCESS':
      return { loading: false, error: null, data: action.payload };
    case 'ERROR':
      return { loading: false, error: action.payload, data: [] };
    default:
      return state;
  }
}

export function useDataState() {
  const [state, dispatch] = useReducer(reducer, {
    loading: false,
    error: null,
    data: [],
  });

  return { state, dispatch };
}
```

