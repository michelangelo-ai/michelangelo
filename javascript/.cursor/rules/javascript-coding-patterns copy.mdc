## Data Transformation Patterns

### Object Path Access
Pattern from [packages/core/utils/object-utils.ts](mdc:javascript/packages/core/utils/object-utils.ts):

```tsx
export function getObjectValue<T = unknown>(
  obj: Record<string, any>,
  accessor: string | ((obj: any) => T),
  defaultValue?: T
): T | undefined {
  if (typeof accessor === 'function') {
    const result = accessor(obj);
    return result || defaultValue;
  }

  if (typeof accessor === 'string') {
    const keys = accessor.split('.');
    let current = obj;
    
    for (const key of keys) {
      if (current?.[key] === undefined) {
        return defaultValue;
      }
      current = current[key];
    }
    
    return current;
  }

  return defaultValue;
}
```

### String Utilities
Pattern from [packages/core/utils/string-utils.ts](mdc:javascript/packages/core/utils/string-utils.ts):

```tsx
export function capitalizeFirstLetter(str: string): string {
  return str.charAt(0).toUpperCase() + str.slice(1);
}

export function isAbsoluteURL(url: string): boolean {
  try {
    new URL(url);
    return true;
  } catch {
    return false;
  }
}

export function sentenceCaseEnumValue(
  value: string,
  prefix: string | RegExp = ''
): string {
  if (typeof value !== 'string') return value;
  
  const cleanValue = typeof prefix === 'string' 
    ? value.replace(prefix, '')
    : value.replace(prefix, '');
    
  return cleanValue
    .split('_')
    .map(word => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase())
    .join(' ');
}
```

## Error Handling Patterns

### Error Boundary
Pattern for React error boundaries:

```tsx
import { Component, ErrorInfo, ReactNode } from 'react';

interface State {
  hasError: boolean;
  error?: Error;
}

export class ErrorBoundary extends Component<
  { children: ReactNode; fallback?: ReactNode },
  State
> {
  constructor(props: any) {
    super(props);
    this.state = { hasError: false };
  }

  static getDerivedStateFromError(error: Error): State {
    return { hasError: true, error };
  }

  componentDidCatch(error: Error, errorInfo: ErrorInfo) {
    console.error('Error caught by boundary:', error, errorInfo);
  }

  render() {
    if (this.state.hasError) {
      return this.props.fallback || <div>Something went wrong.</div>;
    }

    return this.props.children;
  }
}
```

### Async Error Handling
Pattern for handling async operations:

```tsx
export function useAsyncOperation<T>() {
  const [state, setState] = useState<{
    loading: boolean;
    error: string | null;
    data: T | null;
  }>({
    loading: false,
    error: null,
    data: null,
  });

  const execute = useCallback(async (operation: () => Promise<T>) => {
    setState(prev => ({ ...prev, loading: true, error: null }));
    
    try {
      const result = await operation();
      setState({ loading: false, error: null, data: result });
      return result;
    } catch (error) {
      const errorMessage = error instanceof Error ? error.message : 'Unknown error';
      setState({ loading: false, error: errorMessage, data: null });
      throw error;
    }
  }, []);

  return { ...state, execute };
}
```

## Performance Patterns

### Memoization
Pattern for performance optimization:

```tsx
import { memo, useMemo, useCallback } from 'react';

export const OptimizedComponent = memo(function OptimizedComponent({
  items,
  onItemClick,
  filter
}: Props) {
  const filteredItems = useMemo(() => {
    return items.filter(item => 
      filter ? item.name.includes(filter) : true
    );
  }, [items, filter]);

  const handleItemClick = useCallback((itemId: string) => {
    onItemClick?.(itemId);
  }, [onItemClick]);

  return (
    <div>
      {filteredItems.map(item => (
        <ItemComponent
          key={item.id}
          item={item}
          onClick={handleItemClick}
        />
      ))}
    </div>
  );
});
```

### Lazy Loading
Pattern for code splitting:

```tsx
import { lazy, Suspense } from 'react';

const LazyComponent = lazy(() => import('./LazyComponent'));

export function ParentComponent() {
  return (
    <Suspense fallback={<div>Loading...</div>}>
      <LazyComponent />
    </Suspense>
  );
}
```

## Form Patterns

### Controlled Components
Pattern for form handling:

```tsx
import { useState, useCallback } from 'react';

export function FormComponent({ onSubmit }: Props) {
  const [formData, setFormData] = useState({
    name: '',
    email: '',
    description: '',
  });

  const handleChange = useCallback((field: string, value: string) => {
    setFormData(prev => ({ ...prev, [field]: value }));
  }, []);

  const handleSubmit = useCallback((e: FormEvent) => {
    e.preventDefault();
    onSubmit(formData);
  }, [formData, onSubmit]);

  return (
    <form onSubmit={handleSubmit}>
      <Input
        value={formData.name}
        onChange={e => handleChange('name', e.target.value)}
        placeholder="Name"
      />
      <Input
        value={formData.email}
        onChange={e => handleChange('email', e.target.value)}
        placeholder="Email"
      />
      <Textarea
        value={formData.description}
        onChange={e => handleChange('description', e.target.value)}
        placeholder="Description"
      />
      <Button type="submit">Submit</Button>
    </form>
  );
}
```

These patterns provide a solid foundation for consistent, maintainable, and performant JavaScript/TypeScript development in the Michelangelo project. They leverage modern React patterns, TypeScript best practices, and the established conventions from the existing codebase.
