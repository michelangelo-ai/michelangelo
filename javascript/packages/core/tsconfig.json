{
  "extends": "../../tsconfig.base.json",
  "include": ["."],
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "moduleResolution": "node",
    "noEmit": false,
    "jsx": "react-jsx",
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@ma/gen-api/*": ["../../gen/grpc/michelangelo/api/*"],
      "@ma/gen-k8s/*": ["../../gen/grpc/k8s.io/*"]
    }
  }
}
