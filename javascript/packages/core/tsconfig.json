{
  "extends": "../../tsconfig.base.json",
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["dist/**"],
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "moduleResolution": "bundler",
    "noEmit": false,
    "jsx": "react-jsx",
    "outDir": "dist",
    "rootDir": ".",
    "declarationMap": true,
    "sourceMap": true,
    "preserveSymlinks": true,
    "types": ["vitest/globals"]
  }
}
