import calendar
import json
import numpy
import os
import subprocess
import time

import triton_python_backend_utils as pb_utils

from vllm import LLM, SamplingParams


class Model():
    def __init__(self):
        self.logger = pb_utils.Logger

        # TODO: default_max_tokens should be model specific
        self.default_max_tokens = 512
        self.default_top_p = 1
        self.default_temperature = 1
        self.num_return_sequences = 1
        self.tensor_parallel_size = 1
        self.gpu_memory_utilization = 0.9

        gpu_count_check = subprocess.run(['nvidia-smi -L | wc -l'], shell=True, stdout=subprocess.PIPE)
        gpu_count = int(gpu_count_check.stdout.decode().strip())
        if gpu_count > 1 and gpu_count < 9:
            self.tensor_parallel_size = gpu_count

        # We have pre-downloaded the model binary to the below model path.
        model_path = os.path.dirname(os.path.realpath(__file__))
        self.llm = LLM(model=model_path, tensor_parallel_size=self.tensor_parallel_size, gpu_memory_utilization=self.gpu_memory_utilization)

    def execute(self, inputs):
        questions = []

        # Logging using self.logger will allow logs to show up in the the triton log.
        if len(inputs) == 0:
            self.logger.log_info("Inputs are empty, no responses will be generated.")

        # Inputs is a map of a tensor. Since the 0th axis corresponds to the batch, we loop through
        # the 0th index to get the entire list of questions.
        questions = [prompt[0].decode() for prompt in inputs.get("prompt")]

        # The following inputs are required for the unified gen AI input that's compatible
        # with the open AI standard. Since these properties are assumed to be identical for
        # each request in the batch, we only look at the first element for each.
        max_tokens = int(inputs.get("max_tokens")[0, 0])
        # TODO: condition for max_tokens should be model specific
        max_tokens = self.default_max_tokens if max_tokens < 1 else max_tokens
        top_p = float(inputs.get("top_p")[0, 0])
        top_p = self.default_top_p if top_p < 0.01 or top_p > 1. else top_p
        temperature = float(inputs.get("temperature")[0, 0])
        temperature = self.default_temperature if temperature > 1. else temperature
        temperature = 0.01 if temperature < 0.01 else temperature
        num_return_sequences = int(inputs.get("n")[0, 0])
        num_return_sequences = self.num_return_sequences if num_return_sequences < 1 or num_return_sequences > 32 else num_return_sequences

        answers = []
        results = []
        responses = []
        sampling_params = SamplingParams(
            max_tokens=max_tokens,
            n=num_return_sequences,
            temperature=temperature,
            top_p=top_p
        )
        try:
            answers = self.llm.generate(
                questions,
                sampling_params,
                use_tqdm=False,
            )
        except (ValueError, Exception) as e:
            error = str(e)
            self.logger.log_error("Exception during text generation: " + error)
            error_type = "USER" if isinstance(e, ValueError) else "SYSTEM"
            for _ in range(len(questions)):
                results.append("")
            response = {
                "exception": error,
                "cause": error_type
            }
            responses.append(json.dumps(response))
        else:
            # Here, we generate a numpy array with the number outputs as the number of elements in the batch.
            for answer in answers:
                results.append(answer.outputs[0].text)

                logprobs = answer.outputs[0].logprobs
                finish_reason = answer.outputs[0].finish_reason
                prompt_tokens = len(answer.prompt_token_ids)
                completion_tokens = len(answer.outputs[0].token_ids)
                total_tokens = prompt_tokens + completion_tokens
                current_GMT = time.gmtime()
                time_stamp = calendar.timegm(current_GMT)
                response = {
                    "id": "",
                    "object": "text_completion",
                    "created": time_stamp,
                    "model": "",
                    "system_fingerprint": "",
                    "exception": "",
                    "cause": "",
                    "choices": [
                        {
                            "text": answer.outputs[0].text,
                            "index": 0,
                            "logprobs": logprobs,
                            "finish_reason": finish_reason,
                        }
                    ],
                    "usage": {
                        "prompt_tokens": prompt_tokens,
                        "completion_tokens": completion_tokens,
                        "total_tokens": total_tokens,
                    },
                }
                responses.append(json.dumps(response))

        responses_nparray = numpy.array(responses, dtype=object).reshape(len(questions), 1)
        results_nparray = numpy.array(results, dtype=object).reshape(len(questions), 1)

        # The expected output is a map of input name to the numpy ndarray.
        return {"text_json": results_nparray, "response": responses_nparray}


def get_model():
    return Model()
