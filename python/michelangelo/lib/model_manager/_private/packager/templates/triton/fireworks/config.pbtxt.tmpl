name: "{{model_name}}"
backend: "fireworks"
model_transaction_policy {
  decoupled: True
}


input: [
  {
    name: "prompt"
    data_type: TYPE_STRING
    dims: [ 1, 1 ]
  },
  {
    name: "max_tokens"
    data_type: TYPE_INT32
    dims: [ 1, 1 ]
  },
  {
    name: "top_p"
    data_type: TYPE_FP32
    dims: [ 1, 1 ],
    optional: true
  },
  {
    name: "temperature"
    data_type: TYPE_FP32
    dims: [ 1, 1 ],
    optional: true
  },
  {
    name: "n"
    data_type: TYPE_INT32
    dims: [ 1, 1 ],
    optional: true
  }
]
output: [
  {
    name: "text_json"
    data_type: TYPE_STRING
    dims: [ 1, 1 ]
  }
]

instance_group [
  {
    count: 1
    kind: KIND_CPU
  }
]
