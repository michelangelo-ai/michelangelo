--- a/go/components/ingester/controller_test.go
+++ b/go/components/ingester/controller_test.go
@@ -512,3 +512,117 @@ func TestHelperFunctions(t *testing.T) {
 		assert.Equal(t, defaultRequeuePeriod, r2.getRequeuePeriod())
 	})
 }
+
+func TestSchemeGVKResolution(t *testing.T) {
+	scheme := runtime.NewScheme()
+	require.NoError(t, v2.AddToScheme(scheme))
+	seen := map[string]bool{}
+	for _, obj := range v2.AllCRDObjects {
+		gvks, _, err := scheme.ObjectKinds(obj)
+		require.NoError(t, err)
+		require.NotEmpty(t, gvks)
+		kind := gvks[0].Kind
+		assert.NotEmpty(t, kind)
+		assert.False(t, seen[kind])
+		seen[kind] = true
+	}
+}
