diff --git a/go/services/pipeline/executor/runner.go b/go/services/pipeline/executor/runner.go
index a3f21bc..8d4e92f 100644
--- a/go/services/pipeline/executor/runner.go
+++ b/go/services/pipeline/executor/runner.go
@@ -42,18 +42,31 @@ func (r *Runner) Execute(ctx context.Context, task *Task) (*Result, error) {
 	start := time.Now()

-	// Fetch feature data for all entities
-	features := make([]FeatureRow, 0, len(task.EntityIDs))
-	for _, id := range task.EntityIDs {
-		row, err := r.store.GetFeatures(ctx, id)
-		if err != nil {
-			return nil, fmt.Errorf("fetch features for %s: %w", id, err)
-		}
-		features = append(features, row)
-	}
+	// Batch fetch feature data for all entities in one round-trip
+	features, err := r.store.GetFeaturesBatch(ctx, task.EntityIDs)
+	if err != nil {
+		return nil, fmt.Errorf("batch fetch features: %w", err)
+	}

 	result, err := r.model.Predict(ctx, features)
 	if err != nil {
 		return nil, fmt.Errorf("predict: %w", err)
 	}

+	r.metrics.RecordLatency("execute", time.Since(start))
 	return result, nil
 }

