load("@io_bazel_rules_go//go:def.bzl", "go_library")
load("@io_bazel_rules_go//proto:def.bzl", "go_proto_library")
load("@rules_proto//proto:defs.bzl", "proto_library")
load("//bazel/rules/proto:kube_proto_sql.bzl", "kube_proto_sql")
load("//bazel/rules/proto:kube_proto_yaml.bzl", "kube_proto_yaml")

# ==============================================================================
# SHOWCASE: ALL AVAILABLE COMPILERS IN MICHELANGELO
# ==============================================================================

proto_library(
    name = "showcase_proto",
    srcs = ["showcase.proto"],
    import_prefix = "michelangelo",
    strip_import_prefix = "/proto",
    visibility = ["//visibility:public"],
    deps = [
        "//proto/api:api_proto",
    ],
)

# ------------------------------------------------------------------------------
# TARGET 1: Maximum Compilers Together (Non-Conflicting)
# ------------------------------------------------------------------------------
# This target uses the maximum number of compilers that can work together
go_proto_library(
    name = "showcase_all_compilers",
    compilers = [
        # Core protobuf generation (choose one):
        "@io_bazel_rules_go//proto:gogoslick_proto",  # Optimized .pb.go
        # "@io_bazel_rules_go//proto:go_proto",        # Standard .pb.go (conflicts with gogoslick)
        # "//bazel/rules/proto:go_kubeproto",          # K8s .pb.go (conflicts with gogoslick)

        # RPC frameworks:
        "//bazel/rules/proto:go_yarpc",               # .pb.yarpc.go - YARPC RPC
        "//bazel/rules/proto:go_kubeyarpc",           # .pb.kubeyarpc.go - K8s YARPC

        # Validation:
        "//bazel/rules/proto:go_validation",          # .pb.validation.go - Field validation
        "//bazel/rules/proto:go_ext",                 # .ext.go - Extension validation with registry
    ],
    importpath = "github.com/michelangelo-ai/michelangelo/proto/test/all_compilers_showcase",
    proto = ":showcase_proto",
    visibility = ["//visibility:public"],
    deps = [
        "//proto/api:go_default_library",
        "@com_github_gogo_protobuf//gogoproto:go_default_library",
    ],
)

# ------------------------------------------------------------------------------
# TARGET 2: Standard Go Proto Only
# ------------------------------------------------------------------------------
go_proto_library(
    name = "showcase_standard",
    compilers = [
        "@io_bazel_rules_go//proto:go_proto",  # Standard .pb.go
    ],
    importpath = "github.com/michelangelo-ai/michelangelo/proto/test/all_compilers_showcase",
    proto = ":showcase_proto",
    visibility = ["//visibility:public"],
)

# ------------------------------------------------------------------------------
# TARGET 3: Kubernetes-Focused Stack
# ------------------------------------------------------------------------------
go_proto_library(
    name = "showcase_kubernetes",
    compilers = [
        "//bazel/rules/proto:go_kubeproto",     # K8s-aware .pb.go
        "//bazel/rules/proto:go_kubeyarpc",     # K8s YARPC services
        "//bazel/rules/proto:go_validation",    # Validation
    ],
    importpath = "github.com/michelangelo-ai/michelangelo/proto/test/all_compilers_showcase",
    proto = ":showcase_proto",
    visibility = ["//visibility:public"],
    deps = [
        "//proto/api:go_default_library",
        "@com_github_gogo_protobuf//gogoproto:go_default_library",
        "@io_k8s_api//core/v1:core",
        "@io_k8s_apimachinery//pkg/apis/meta/v1:go_default_library",
    ],
)

# ------------------------------------------------------------------------------
# TARGET 4: Validation-Focused Stack
# ------------------------------------------------------------------------------
go_proto_library(
    name = "showcase_validation",
    compilers = [
        "@io_bazel_rules_go//proto:gogoslick_proto",  # Base proto
        "//bazel/rules/proto:go_validation",          # Standard validation
        "//bazel/rules/proto:go_ext",                 # Extension validation
    ],
    importpath = "github.com/michelangelo-ai/michelangelo/proto/test/all_compilers_showcase",
    proto = ":showcase_proto",
    visibility = ["//visibility:public"],
    deps = [
        "//proto/api:go_default_library",
        "@com_github_gogo_protobuf//gogoproto:go_default_library",
    ],
)

# ------------------------------------------------------------------------------
# TARGET 5: RPC-Focused Stack
# ------------------------------------------------------------------------------
go_proto_library(
    name = "showcase_rpc",
    compilers = [
        "@io_bazel_rules_go//proto:gogoslick_proto",  # Base proto
        "//bazel/rules/proto:go_yarpc",               # YARPC RPC
        "//bazel/rules/proto:go_kubeyarpc",           # K8s YARPC
    ],
    importpath = "github.com/michelangelo-ai/michelangelo/proto/test/all_compilers_showcase",
    proto = ":showcase_proto",
    visibility = ["//visibility:public"],
    deps = [
        "//proto/api:go_default_library",
        "@com_github_gogo_protobuf//gogoproto:go_default_library",
    ],
)

# ------------------------------------------------------------------------------
# SQL Schema Generation (Separate target)
# ------------------------------------------------------------------------------
kube_proto_sql(
    name = "showcase_sql",
    visibility = ["//visibility:public"],
    deps = [":showcase_proto"],
)

# ------------------------------------------------------------------------------
# YAML Manifest Generation (Separate target)
# ------------------------------------------------------------------------------
kube_proto_yaml(
    name = "showcase_yaml",
    visibility = ["//visibility:public"],
    deps = [":showcase_proto"],
)

# ------------------------------------------------------------------------------
# Go Library (embeds the all_compilers target)
# ------------------------------------------------------------------------------
go_library(
    name = "go_default_library",
    embed = [":showcase_all_compilers"],
    importpath = "github.com/michelangelo-ai/michelangelo/proto/test/all_compilers_showcase",
    visibility = ["//visibility:public"],
)

# ==============================================================================
# SUMMARY OF ALL AVAILABLE COMPILERS:
# ==============================================================================
# 1. @io_bazel_rules_go//proto:go_proto        - Standard .pb.go
# 2. @io_bazel_rules_go//proto:gogoslick_proto - Optimized .pb.go (Gogo)
# 3. //bazel/rules/proto:go_kubeproto          - Kubernetes .pb.go
# 4. //bazel/rules/proto:go_yarpc              - .pb.yarpc.go (YARPC RPC)
# 5. //bazel/rules/proto:go_kubeyarpc          - .pb.kubeyarpc.go (K8s YARPC)
# 6. //bazel/rules/proto:go_validation         - .pb.validation.go (Validation)
# 7. //bazel/rules/proto:go_ext                - .ext.go (Extension validation) ✨ NEW
# 8. //bazel/rules/proto:go_kubeproto_unittest - .pb.record.go (Testing)
# 9. kube_proto_sql                            - .sql (SQL schema)
# 10. kube_proto_yaml                          - .yaml (K8s manifests)
#
# Note: Compilers 1, 2, and 3 conflict as they all generate .pb.go files
# ==============================================================================
