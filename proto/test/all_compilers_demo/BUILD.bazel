load("@io_bazel_rules_go//go:def.bzl", "go_library")
load("@io_bazel_rules_go//proto:def.bzl", "go_proto_library")
load("@rules_proto//proto:defs.bzl", "proto_library")
load("//bazel/rules/proto:kube_proto_sql.bzl", "kube_proto_sql")
load("//bazel/rules/proto:kube_proto_yaml.bzl", "kube_proto_yaml")

# Define the proto library
proto_library(
    name = "demo_proto",
    srcs = ["demo.proto"],
    import_prefix = "michelangelo",
    strip_import_prefix = "/proto",
    visibility = ["//visibility:public"],
    deps = [
        "//proto/api:api_proto",
    ],
)

# Generate Go code with ALL compilers (except conflicting ones)
go_proto_library(
    name = "demo_go_proto_all",
    compilers = [
        "@io_bazel_rules_go//proto:gogoslick_proto",  # Optimized .pb.go files
        "//bazel/rules/proto:go_yarpc",               # .pb.yarpc.go files for RPC
        "//bazel/rules/proto:go_kubeyarpc",           # .pb.kubeyarpc.go files
        "//bazel/rules/proto:go_validation",          # .pb.validation.go files
        "//bazel/rules/proto:go_ext",                 # .ext.go files
    ],
    importpath = "github.com/michelangelo-ai/michelangelo/proto/test/all_compilers_demo",
    proto = ":demo_proto",
    visibility = ["//visibility:public"],
    deps = [
        "//proto/api:go_default_library",
        "@com_github_gogo_protobuf//gogoproto:go_default_library",
    ],
)

# Generate SQL schema
kube_proto_sql(
    name = "demo_sql",
    visibility = ["//visibility:public"],
    deps = [":demo_proto"],
)

# Generate YAML configuration
kube_proto_yaml(
    name = "demo_yaml",
    visibility = ["//visibility:public"],
    deps = [":demo_proto"],
)

# Go library embedding all generated files
go_library(
    name = "go_default_library",
    embed = [":demo_go_proto_all"],
    importpath = "github.com/michelangelo-ai/michelangelo/proto/test/all_compilers_demo",
    visibility = ["//visibility:public"],
)
