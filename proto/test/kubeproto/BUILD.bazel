load("@io_bazel_rules_go//go:def.bzl", "go_library")
load("@io_bazel_rules_go//proto:def.bzl", "go_proto_library")
load("@rules_proto//proto:defs.bzl", "proto_library")

# gazelle:go_proto_compilers //bazel/rules/proto:go_kubeproto,//bazel/rules/proto:go_validation,//bazel/rules/proto:go_kubeproto_unittest

proto_library(
    name = "kubeproto_proto",
    srcs = [
        "crd_info_ut.proto",
        "gogoproto_ut.proto",
        "groupversion_info_ut.proto",
        "indexing.proto",
        "project_ut.proto",
        "testobject.proto",
        "validation_ut.proto",
    ],
    import_prefix = "michelangelo",
    strip_import_prefix = "/proto",
    visibility = ["//visibility:public"],
    deps = [
        "//proto/api:api_proto",
        "//proto/api/v2:v2_proto",
        "@com_google_protobuf//:any_proto",
        "@com_google_protobuf//:duration_proto",
        "@com_google_protobuf//:struct_proto",
        "@com_google_protobuf//:timestamp_proto",
        "@io_k8s_api//core/v1:v1_proto",
        "@io_k8s_apimachinery//pkg/apis/meta/v1:v1_proto",
    ],
)

go_proto_library(
    name = "kubeproto_go_proto",
    compilers = [
        "//bazel/rules/proto:go_kubeproto",
        "//bazel/rules/proto:go_validation",
        "//bazel/rules/proto:go_kubeyarpc",
        "//bazel/rules/proto:go_kubeproto_unittest",
    ],
    importpath = "github.com/michelangelo-ai/michelangelo/proto/test/kubeproto",
    proto = ":kubeproto_proto",
    visibility = ["//visibility:public"],
    deps = [
        "//proto/api:go_default_library",
        "//proto/api/v2:go_default_library",
        "@io_k8s_api//core/v1:core",
        "@io_k8s_apimachinery//pkg/apis/meta/v1:go_default_library",
    ],
)

go_library(
    name = "go_default_library",
    embed = [":kubeproto_go_proto"],
    importpath = "github.com/michelangelo-ai/michelangelo/proto/test/kubeproto",
    visibility = ["//visibility:public"],
)
