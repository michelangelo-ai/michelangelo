	responseJSON := logging.MarshalToString(response)
	errMsg := ""
	if grpcErr != nil {
		errMsg = grpcErr.Error()
	}

	event := &logging.AuditLogEvent{
		Namespace:  requestNamespace,
		EntityType: entityType,
		EntityName: requestName,
		Procedure:  procedure,
		Request:    requestJSON,
		Response:   responseJSON,
		Error:      errMsg,
	}

	return event
}

