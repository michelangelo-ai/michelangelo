## Workflow Integration Patterns

### Temporal/Cadence Activity Pattern

```go
// Activity interface
type Activities interface {
    ProcessData(ctx context.Context, input DataInput) (DataOutput, error)
    ValidateResults(ctx context.Context, results Results) error
}

// Activity implementation
func (a *activities) ProcessData(ctx context.Context, input DataInput) (DataOutput, error) {
    // Use structured logging
    logger := activity.GetLogger(ctx)
    logger.Info("Processing data", "inputSize", len(input.Data))
    
    // Implementation
    return output, nil
}
```

### Workflow Definition Pattern

```go
func MyWorkflow(ctx workflow.Context, input WorkflowInput) (WorkflowOutput, error) {
    ctx = workflow.WithActivityOptions(ctx, workflow.ActivityOptions{
        StartToCloseTimeout: time.Minute * 10,
        RetryPolicy: &temporal.RetryPolicy{
            MaximumAttempts: 3,
        },
    })
    
    var activities Activities
    var result DataOutput
    err := workflow.ExecuteActivity(ctx, activities.ProcessData, input.Data).Get(ctx, &result)
    if err != nil {
        return WorkflowOutput{}, err
    }
    
    return WorkflowOutput{Result: result}, nil
}
```

## Performance Patterns

### Context Usage

```go
// Always accept context as first parameter
func ProcessRequest(ctx context.Context, req Request) error {
    // Check for cancellation
    select {
    case <-ctx.Done():
        return ctx.Err()
    default:
    }
    
    // Use context for downstream calls
    return downstream.Call(ctx, req)
}
```

### Resource Management

```go
// Use defer for cleanup
func ProcessFile(filename string) error {
    file, err := os.Open(filename)
    if err != nil {
        return err
    }
    defer file.Close()
    
    // Process file
    return nil
}

// Use sync.Pool for object reuse
var bufferPool = sync.Pool{
    New: func() interface{} {
        return make([]byte, 0, 1024)
    },
}

func ProcessData(data []byte) error {
    buf := bufferPool.Get().([]byte)
    defer bufferPool.Put(buf[:0])
    
    // Use buffer
    return nil
}
```

## Security Patterns

### Input Validation

```go
import (
    "net"
    "net/mail"
    "net/url"
    "regexp"
    "github.com/google/uuid"
)

// Validation functions pattern
func validateEmail(email string) error {
    _, err := mail.ParseAddress(email)
    return err
}

func validateUUID(id string) error {
    _, err := uuid.Parse(id)
    return err
}

func validateIP(ip string) error {
    if net.ParseIP(ip) == nil {
        return fmt.Errorf("invalid IP address: %s", ip)
    }
    return nil
}
```

### RBAC Integration

```go
// Use Kubernetes RBAC patterns
func (h *handler) checkPermissions(ctx context.Context, namespace, resource, verb string) error {
    // Implementation for permission checking
    return nil
}

func (h *handler) Create(ctx context.Context, obj client.Object) error {
    if err := h.checkPermissions(ctx, obj.GetNamespace(), "pipelines", "create"); err != nil {
        return status.Errorf(codes.PermissionDenied, "insufficient permissions: %v", err)
    }
    
    // Continue with creation
    return h.storage.Create(ctx, obj)
}
```
