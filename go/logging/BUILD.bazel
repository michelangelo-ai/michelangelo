load("@io_bazel_rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "go_default_library",
    srcs = [
        "audit_log_struct.go",
        "audit_logger.go",
        "constants.go",
        "helper_logger.go",
        "noop_logr_sink.go",
        "service_logger.go",
