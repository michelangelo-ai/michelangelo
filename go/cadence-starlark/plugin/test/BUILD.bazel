load("@io_bazel_rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "go_default_library",
    srcs = [
        "module.go",
        "plugin.go",
    ],
    importpath = "github.com/michelangelo-ai/michelangelo/go/cadence-starlark/plugin/test",
    visibility = ["//visibility:public"],
    deps = [
        "//go/cadence-starlark/cadstar:go_default_library",
        "//go/cadence-starlark/star:go_default_library",
        "@io_temporal_go_sdk//temporal:go_default_library",
        "@net_starlark_go//starlark:go_default_library",
    ],
)

go_test(
    name = "go_default_test",
    srcs = ["module_test.go"],
    embed = [":go_default_library"],
    deps = [
        "@com_github_stretchr_testify//require:go_default_library",
        "@net_starlark_go//starlark:go_default_library",
    ],
)
